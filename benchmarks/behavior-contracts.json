        {
          "file": "skills/start-workflow/SKILL.md",
          "pattern": "root-start вызывает orchestrator НАПРЯМУЮ|flat-chain|flat.chain"
        },
        {
          "file": "docs/start-workflow.md",
          "pattern": "Task\\(orchestrator.*directly|launches .*Task\\(orchestrator"
