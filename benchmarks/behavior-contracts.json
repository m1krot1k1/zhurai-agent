      "required_regex": [
        {
          "file": "agents/start.md",
          "pattern": "Task\\(subagent_type=\\\"orchestrator\\\""
        },
        {
          "file": "agents/start.md",
          "pattern": "НАПРЯМУЮ"
        },
        {
          "file": "agents/start.md",
          "pattern": "Worker-start.*УДАЛЁН|worker.*УДАЛЁН|DEPRECATED"
        },
        {
          "file": "agents/start.md",
          "pattern": "MUST NOT.*Task\\(orchestrator\\)"
        },
        {
          "file": "rules/specialists.mdc",
          "pattern": "УПЛОЩЁННАЯ"
        },
        {
          "file": "docs/delegation-chain.md",
          "pattern": "Task\\(orchestrator.*НАПРЯМУЮ|orchestrator.*НАПРЯМУЮ"
