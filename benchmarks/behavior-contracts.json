          "pattern": "Task\\(orchestrator, ORIGINAL_REQUEST"
        }
      ],
      "forbidden_regex": [
        {
          "file": "agents/start.md",
          "pattern": "Task\\(subagent_type=\\\"code\\\""
        },
        {
          "file": "agents/start.md",
          "pattern": "STRUCTURAL PRE-FLIGHT"
        },
        {
          "file": "agents/start.md",
          "pattern": "AGENT COUNCIL"
        },
        {
          "file": "skills/start-workflow/SKILL.md",
          "pattern": "Cursor не даёт `Task` tool вложенным subagent'ам|Worker не имеет Task tool"
        },
        {
          "file": "docs/start-workflow.md",
          "pattern": "Cursor does not give the `Task` tool to nested subagents"
